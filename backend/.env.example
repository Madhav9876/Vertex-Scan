# Vertex Scan Backend Configuration — EXAMPLE ONLY
# Copy to .env and fill in real values. .env is git-ignored; never commit secrets.
PORT=3001
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# Database — Supabase (hosted PostgreSQL)
# ─────────────────────────────────────────────────────────────
# The app reads DATABASE_URL first. URL-encode special characters in the
# password (e.g. "@" -> %40). Get the string from the Supabase dashboard:
# Project Settings -> Database -> Connection string.
#
# Direct connection (for migrations / single instance):
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
#
# RECOMMENDED for runtime (IPv4-friendly Transaction pooler, port 6543):
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# TLS is enabled automatically when DATABASE_URL is set. Set DB_SSL=false only
# for a local Postgres without TLS.
# DB_SSL=false

# Supabase project details
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json

# ─────────────────────────────────────────────────────────────
# Legacy per-field config (only used when DATABASE_URL is not set)
# ─────────────────────────────────────────────────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=vertex_scan
# DB_USER=vertex_app
# DB_PASSWORD=CHANGE_ME_strong_db_password

# JWT — generate a long random secret, e.g. `openssl rand -hex 48`
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_48
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated trusted origins)
CORS_ORIGIN=http://localhost:5173

# Outbound scanning limits (abuse protection)
MAX_CONCURRENT_SCANS=3
MAX_SCANS_PER_USER_PER_DAY=50
